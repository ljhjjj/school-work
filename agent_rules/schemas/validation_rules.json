{
  "paths": {
    "pattern_mode": "template_then_regex",
    "description": "Evaluate patterns as regex only AFTER substituting {subject}, {week}, and {session} with actual values.",
    "note_file": {
      "pattern": "^{subject}/{subject} {week}-{session}\\.md$",
      "example": "고체역학/고체역학 3-1.md"
    },
    "plan_file": {
      "pattern": "^{subject}/{subject}_{week}-{session}_PLAN\\.md$",
      "example": "고체역학/고체역학_3-1_PLAN.md"
    }
  },
  "encoding": "utf-8",
  "markdown_structure": {
    "h1": {
      "required_count": 1,
      "pattern": "^# .+ \\d+-\\d+: .+$"
    },
    "h2": {
      "pattern": "^## \\d+\\. .+",
      "require_horizontal_rule_after_section": true
    },
    "h3": {
      "pattern": "^### \\d+\\) .+",
      "required": false
    }
  },
  "latex": {
    "inline_pattern": "\\$[^$\\n]+\\$",
    "block_delimiter": "$$",
    "block_must_be_standalone": true,
    "forbidden_patterns": [
      ".*\\$\\$[^\\n]+\\$\\$.*",
      "<math[\\s>]",
      "</math>"
    ],
    "discouraged_macros": [
      {
        "pattern": "\\\\underbrace",
        "severity": "warning",
        "action": "report_only"
      },
      {
        "pattern": "\\\\overbrace",
        "severity": "warning",
        "action": "report_only"
      },
      {
        "pattern": "\\\\begin\\{array\\}",
        "severity": "warning",
        "action": "report_only"
      },
      {
        "pattern": "\\\\begin\\{aligned\\}",
        "severity": "warning",
        "action": "report_only"
      }
    ]
  },
  "normal_status_tags": {
    "description": "정상 판정/범위 관리 태그. 발견되어도 validation warning으로 간주하지 않는다.",
    "search_terms": [
      "[확정]",
      "[보정]",
      "[필기 우선]",
      "[TXT 우선]",
      "[자료 PDF 초과 범위]",
      "[제외]"
    ]
  },
  "residual_issue_tags": {
    "description": "최종 리포트의 [잔여 이슈]에 포함해야 하는 미해결 태그.",
    "search_terms": [
      "[?]",
      "[필기 판독 불확실]",
      "[대응 불확실]",
      "[TXT 누락 의심]",
      "[확인 필요]",
      "[수동 입력 필요]"
    ],
    "report_section": "잔여 이슈"
  },
  "warning_tags": {
    "description": "Backward-compatible alias for residual_issue_tags. Do not include normal_status_tags here.",
    "search_terms": [
      "[?]",
      "[필기 판독 불확실]",
      "[대응 불확실]",
      "[TXT 누락 의심]",
      "[확인 필요]",
      "[수동 입력 필요]"
    ],
    "report_section": "잔여 이슈",
    "false_positive_exceptions": [
      "## Validation Report",
      "### 잔여 이슈",
      "[x] Blocker 처리 종료"
    ]
  }
}
