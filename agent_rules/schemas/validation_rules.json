{
  "paths": {
    "pattern_mode": "template_then_regex",
    "description": "Evaluate patterns as regex only AFTER substituting {subject}, {week}, and {session} with actual values.",
    "note_file": {
      "pattern": "^output/{subject}/{subject} {week}-{session}\\.md$",
      "example": "output/고체역학/고체역학 3-1.md"
    },
    "plan_file": {
      "pattern": "^output/{subject}/{subject}_{week}-{session}_PLAN\\.md$",
      "example": "output/고체역학/고체역학_3-1_PLAN.md"
    }
  },
  "encoding": "utf-8",
  "markdown_structure": {
    "h1": {
      "required_count": 1,
      "pattern": "^# .+ \\d+-\\d+: .+$"
    },
    "h2": {
      "pattern": "^## \\d+\\. .+",
      "require_horizontal_rule_at_section_end": true,
      "horizontal_rule_position": "before_next_h2_or_end_of_document",
      "horizontal_rule_must_not_immediately_follow_h2": true
    },
    "h3": {
      "pattern": "^### \\d+\\) .+",
      "required": false
    }
  },
  "input_coverage": {
    "required": true,
    "separate_from_structure_validation": true,
    "plan_sections": [
      "페이지 판독 기록",
      "입력 커버리지 검증"
    ],
    "required_checks": [
      "각 입력 파일의 핵심 항목 반영 여부 확인",
      "페이지별 판독 기록과 최종 본문 대조",
      "여러 페이지 입력 자료는 페이지 단위 체크리스트로 확인",
      "입력 자료의 페이지별 핵심 항목이 최종 노트에 반영되었는지 확인",
      "특정 페이지 또는 특정 용어는 manifest 또는 작업 PLAN에 명시된 경우에만 필수 검증 대상으로 확인",
      "반영하지 않은 입력 항목의 제외 사유 기록",
      "슬라이드 PDF 사용 목적 구분",
      "STT TXT가 있는 경우 강의 흐름과 본문 범위 충돌 여부 확인"
    ],
    "slide_only": {
      "applies_when": {
        "source_path": "lecture_slide.pdf",
        "role": "primary_scope_anchor",
        "scope": "entire_pdf",
        "only_source": true
      },
      "required_checks": [
        "lecture_slide.pdf 전체 페이지 검토 여부 확인",
        "각 슬라이드 또는 슬라이드 구간의 페이지 판독 기록 포함 여부 확인",
        "슬라이드 제목, 섹션 순서, 공식, 그림, 예제 흐름의 최종 본문 반영 여부 확인",
        "제외한 슬라이드가 있는 경우 PLAN 또는 최종 리포트의 제외 사유 기록 여부 확인",
        "외부 자료를 본문 범위 확장용으로 사용하지 않았는지 확인"
      ],
      "plan_sections": [
        "입력 판정",
        "페이지 판독 기록",
        "입력 커버리지 검증"
      ]
    },
    "diagnostic_examples": [
      "handwritten_note.pdf p.3처럼 특정 페이지가 PLAN에 명시된 경우 해당 페이지 반영 여부 확인",
      "reversible/reversed process처럼 특정 용어가 PLAN에 명시된 경우 해당 용어 반영 여부 확인",
      "특정 도식 논증이 PLAN에 명시된 경우 본문 반영 또는 제외 사유 확인"
    ],
    "report_sections": [
      "구조 검증 결과",
      "입력 커버리지 검증 결과"
    ]
  },
  "latex": {
    "inline_pattern": "\\$[^$\\n]+\\$",
    "block_delimiter": "$$",
    "block_must_be_standalone": true,
    "forbidden_patterns": [
      ".*\\$\\$[^\\n]+\\$\\$.*",
      "<math[\\s>]",
      "</math>"
    ],
    "discouraged_macros": [
      {
        "pattern": "\\\\underbrace",
        "severity": "warning",
        "action": "report_only"
      },
      {
        "pattern": "\\\\overbrace",
        "severity": "warning",
        "action": "report_only"
      },
      {
        "pattern": "\\\\begin\\{array\\}",
        "severity": "warning",
        "action": "report_only"
      },
      {
        "pattern": "\\\\begin\\{aligned\\}",
        "severity": "warning",
        "action": "report_only"
      }
    ]
  },
  "normal_status_tags": {
    "description": "정상 판정/범위 관리 태그. 발견되어도 validation warning으로 간주하지 않는다.",
    "search_terms": [
      "[확정]",
      "[보정]",
      "[필기 우선]",
      "[TXT 우선]",
      "[자료 PDF 초과 범위]",
      "[제외]"
    ]
  },
  "residual_issue_tags": {
    "description": "최종 리포트의 [잔여 이슈]에 포함해야 하는 미해결 태그.",
    "search_terms": [
      "[?]",
      "[필기 판독 불확실]",
      "[대응 불확실]",
      "[TXT 누락 의심]",
      "[확인 필요]",
      "[수동 입력 필요]"
    ],
    "report_section": "잔여 이슈"
  },
  "warning_tags": {
    "description": "Backward-compatible alias for residual_issue_tags. Do not include normal_status_tags here.",
    "search_terms": [
      "[?]",
      "[필기 판독 불확실]",
      "[대응 불확실]",
      "[TXT 누락 의심]",
      "[확인 필요]",
      "[수동 입력 필요]"
    ],
    "report_section": "잔여 이슈",
    "false_positive_exceptions": [
      "## Validation Report",
      "### 잔여 이슈",
      "[x] Blocker 처리 종료"
    ]
  }
}
